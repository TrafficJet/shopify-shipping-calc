---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title="Shopify Shipping Blog — Guides & Tips" description="Expert guides on Shopify shipping rates, zones, free shipping strategies, and carrier comparisons.">
  <h1 class="text-3xl font-bold mb-8">Shipping Blog</h1>
  {posts.length === 0 && <p class="text-gray-500">No posts yet — check back soon!</p>}
  <ul class="space-y-6">
    {posts.map(post => (
      <li>
        <a href={`/blog/${post.slug}/`} class="block hover:bg-gray-50 rounded-lg p-4 transition">
          <h2 class="text-xl font-semibold text-sky-700">{post.data.title}</h2>
          <p class="text-sm text-gray-500 mt-1">{post.data.pubDate.toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'})} · {post.data.author}</p>
          <p class="text-gray-600 mt-2 text-sm">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</Base>
