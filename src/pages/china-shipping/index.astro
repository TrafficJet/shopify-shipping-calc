---
import Base from "../../layouts/Base.astro";
import { chinaMethods, countryRates, getCountriesByRegion } from "../../data/china-shipping";

const grouped = getCountriesByRegion();
const regionOrder = ['North America', 'Europe', 'Asia', 'Oceania', 'South America', 'Middle East', 'Africa', 'Europe/Asia'];
---
<Base
  title="China Shipping Rates to All Countries 2026 — ePacket, DHL, FedEx | ShopifyCalc"
  description="Compare China shipping rates to 50+ countries. ePacket, China EMS, DHL Express, FedEx International, UPS Worldwide. 2026 rates from Shenzhen & Shanghai."
>
  <h1 class="text-3xl font-bold mb-3">China Shipping Rates to Every Country (2026)</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg max-w-2xl">
    Compare shipping rates from China to 50+ countries. Includes ePacket, China EMS, DHL Express, FedEx, and UPS. Updated for 2026.
  </p>

  <!-- Method comparison table -->
  <div class="mb-12 overflow-x-auto">
    <h2 class="text-xl font-bold mb-4">Shipping Method Comparison</h2>
    <table class="w-full text-sm border dark:border-gray-700 rounded-xl overflow-hidden">
      <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
          <th class="text-left px-4 py-2 font-medium">Method</th>
          <th class="px-3 py-2 font-medium">Transit</th>
          <th class="px-3 py-2 font-medium">Tracking</th>
          <th class="px-3 py-2 font-medium">Max Weight</th>
          <th class="px-4 py-2 font-medium text-left">Best For</th>
        </tr>
      </thead>
      <tbody class="divide-y dark:divide-gray-700">
        {chinaMethods.map(m => (
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
            <td class="px-4 py-2 font-medium">{m.name}</td>
            <td class="px-3 py-2 text-gray-600 dark:text-gray-400">{m.transitDays}</td>
            <td class="px-3 py-2 text-center">
              {m.trackingLevel === 'full' ? '✅ Full' : m.trackingLevel === 'limited' ? '⚠️ Limited' : '❌ None'}
            </td>
            <td class="px-3 py-2 text-center">{m.maxWeightKg} kg</td>
            <td class="px-4 py-2 text-gray-600 dark:text-gray-400 text-xs">{m.bestFor}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Quick rate calculator -->
  <div class="bg-gray-50 dark:bg-gray-900 border dark:border-gray-700 rounded-xl p-6 max-w-2xl mb-12">
    <h2 class="font-semibold text-lg mb-4">Quick Rate Estimator</h2>
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1 dark:text-gray-300" for="dest-country">Destination Country</label>
        <select id="dest-country" class="w-full border dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-800 dark:text-gray-100">
          {countryRates.map(c => <option value={c.slug}>{c.flag} {c.name}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 dark:text-gray-300" for="pkg-kg">Weight (kg)</label>
        <input id="pkg-kg" type="number" min="0.1" step="0.1" value="0.5"
          class="w-full border dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>
    </div>
    <button id="china-calc-btn"
      class="w-full bg-blue-700 text-white py-2.5 rounded-lg font-semibold text-sm hover:bg-blue-800 transition">
      Compare China Shipping Methods
    </button>
    <div id="china-results" class="mt-5 hidden">
      <div id="china-rates-list" class="space-y-2"></div>
    </div>
  </div>

  <!-- Countries by region -->
  <div class="mb-12">
    <h2 class="text-xl font-bold mb-5">Browse by Country</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {regionOrder.filter(r => grouped[r]).map(region => (
        <div class="border dark:border-gray-700 rounded-xl p-4 bg-gray-50 dark:bg-gray-900">
          <h3 class="font-semibold mb-3 text-sm text-gray-500 dark:text-gray-400 uppercase tracking-wide">{region}</h3>
          <ul class="space-y-1">
            {grouped[region].map(c => (
              <li>
                <a href={`/china-shipping/${c.slug}/`} class="text-sm text-blue-700 dark:text-blue-400 hover:underline">
                  {c.flag} {c.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 rounded-xl p-5 max-w-2xl">
    <h2 class="font-semibold mb-2">Tips for Shipping from China</h2>
    <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2">
      <li>📦 <strong>Under 2 kg:</strong> ePacket is usually the cheapest tracked option to most countries.</li>
      <li>⚡ <strong>Urgent shipments:</strong> DHL Express or FedEx International Priority for 2–5 day delivery.</li>
      <li>💰 <strong>Heavy packages (5–30 kg):</strong> China Post Air Parcel offers significant savings over express.</li>
      <li>🔍 <strong>Customs duty:</strong> Most countries impose import duties on goods over $20–$50 USD.</li>
      <li>🇷🇺 <strong>Russia/Belarus:</strong> Express carriers (DHL/FedEx/UPS) currently unavailable due to sanctions.</li>
    </ul>
  </div>
</Base>

<script define:vars={{ countriesData: JSON.stringify(countryRates), methodsData: JSON.stringify(chinaMethods) }}>
  const countries = JSON.parse(countriesData);
  const methods = JSON.parse(methodsData);
  const isDark = () => document.documentElement.classList.contains('dark');

  document.getElementById('china-calc-btn').addEventListener('click', () => {
    const slug = document.getElementById('dest-country').value;
    const kg = parseFloat(document.getElementById('pkg-kg').value) || 0.5;
    const country = countries.find(c => c.slug === slug);
    if (!country) return;

    const results = methods
      .map(m => {
        const r = country.rates[m.id];
        if (!r) return null;
        const cost = Math.max(r.minCharge, r.perKg * kg);
        return { method: m, cost };
      })
      .filter(Boolean)
      .sort((a, b) => a.cost - b.cost);

    const dark = isDark();
    const list = document.getElementById('china-rates-list');
    list.innerHTML = results.map((r, i) =>
      `<div class="flex items-center justify-between border rounded-lg px-4 py-3 ${
        i === 0
          ? (dark ? 'bg-green-950 border-green-700' : 'bg-green-50 border-green-300')
          : (dark ? 'bg-gray-800 border-gray-700' : 'bg-white border-gray-200')
      }">
        <div>
          ${i === 0 ? `<span class="text-xs font-medium ${dark ? 'text-green-400 bg-green-900' : 'text-green-700 bg-green-100'} rounded px-1.5 mr-2">Cheapest</span>` : ''}
          <span class="font-medium text-sm">${r.method.name}</span>
          <span class="text-xs ${dark ? 'text-gray-400' : 'text-gray-500'} ml-2">${r.method.transitDays}</span>
        </div>
        <span class="font-bold ${i === 0 ? (dark ? 'text-green-400' : 'text-green-700') : (dark ? 'text-gray-100' : 'text-gray-900')}">$${r.cost.toFixed(2)}</span>
      </div>`
    ).join('');

    document.getElementById('china-results').classList.remove('hidden');
  });
</script>
