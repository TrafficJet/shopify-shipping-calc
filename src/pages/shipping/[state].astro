---
import Base from "../../layouts/Base.astro";
import { states, ZONE_MATRIX } from "../../data/states-cities";
import { carriers } from "../../data/carriers-rates";

export function getStaticPaths() {
  return states.map(s => ({ params: { state: s.slug } }));
}

const { state: stateSlug } = Astro.params;
const stateData = states.find(s => s.slug === stateSlug)!;
const originRegion = stateData.cities[0].region;

const regionLabels: Record<string, string> = {
  northeast: 'Northeast', southeast: 'Southeast',
  midwest: 'Midwest', southwest: 'Southwest', west: 'West',
};
const regionLabel = regionLabels[originRegion] ?? originRegion;

// Nearby states (same region, first 5)
const nearbyStates = states
  .filter(s => s.slug !== stateData.slug && s.cities[0]?.region === originRegion)
  .slice(0, 6);

// Key carriers for rate tables
const uspsGA   = carriers.find(c => c.id === 'usps-ground-advantage')!;
const uspsPM   = carriers.find(c => c.id === 'usps-priority-mail')!;
const upsG     = carriers.find(c => c.id === 'ups-ground')!;
const fedexG   = carriers.find(c => c.id === 'fedex-ground')!;

// Destination regions for the table
const destRegions = ['northeast', 'southeast', 'midwest', 'southwest', 'west'] as const;

// Weight tiers to show in the comparison table
const weightTiers = [
  { label: '1 lb', oz: 16 },
  { label: '2 lb', oz: 32 },
  { label: '5 lb', oz: 80 },
  { label: '10 lb', oz: 160 },
  { label: '20 lb', oz: 320 },
];

// Get rate for a carrier/oz/zone combo
function getRate(car: typeof uspsGA, oz: number, zone: number): number | null {
  const tier = car.rates.find(r => r.oz >= oz);
  return tier?.zones[zone] ?? null;
}

// Determine cheapest carrier at 1lb to each destination
function cheapestAtZone(zone: number) {
  const candidates = [
    { name: 'USPS Ground Advantage', rate: getRate(uspsGA, 16, zone) },
    { name: 'USPS Priority Mail',    rate: getRate(uspsPM, 16, zone) },
    { name: 'UPS Ground',            rate: getRate(upsG,   16, zone) },
    { name: 'FedEx Ground',          rate: getRate(fedexG, 16, zone) },
  ].filter(c => c.rate !== null) as { name: string; rate: number }[];
  return candidates.sort((a, b) => a.rate - b.rate)[0];
}

// For schema: compute a representative rate (1lb to same region = zone 2)
const selfZone = ZONE_MATRIX[originRegion][originRegion];
const repRate = getRate(uspsGA, 16, selfZone);

const softwareSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": `${stateData.name} Shipping Rate Calculator`,
  "url": `https://shopify-shipping-calc.com/shipping/${stateData.slug}/`,
  "description": `Free ${stateData.name} shipping rate calculator. Compare USPS, UPS, FedEx, and DHL rates for packages shipped from ${stateData.abbr}. Zone-based pricing updated for 2026.`,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the cheapest way to ship a package from ${stateData.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `For packages under 1 lb shipped from ${stateData.name}, USPS Ground Advantage is typically the cheapest option at $${(repRate ?? 5.49).toFixed(2)}–$11.50 depending on destination. For packages over 1 lb going to nearby states in the ${regionLabel} region (Zone ${selfZone}), USPS Ground Advantage and UPS Ground are competitive. For cross-country shipments (Zone 7–8), compare all four carriers — FedEx Ground sometimes offers better commercial rates.`
      }
    },
    {
      "@type": "Question",
      "name": `How much does it cost to ship from ${stateData.name} to California?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Shipping from ${stateData.name} to California (${originRegion === 'west' ? 'same region, Zone ' + ZONE_MATRIX[originRegion]['west'] : 'Zone ' + ZONE_MATRIX[originRegion]['west']}) costs approximately: USPS Ground Advantage $${getRate(uspsGA, 16, ZONE_MATRIX[originRegion]['west'])?.toFixed(2)} (1 lb), UPS Ground $${getRate(upsG, 16, ZONE_MATRIX[originRegion]['west'])?.toFixed(2)} (1 lb), FedEx Ground $${getRate(fedexG, 16, ZONE_MATRIX[originRegion]['west'])?.toFixed(2) ?? 'varies'} (1 lb). Use our calculator above for exact rates by package weight.`
      }
    },
    {
      "@type": "Question",
      "name": `Does ${stateData.name} sales tax apply to Shopify shipping charges?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${stateData.name} has a ${stateData.taxRate}% state sales tax rate. ${stateData.taxRate === 0 ? `${stateData.name} is one of the few states with no state sales tax, which simplifies tax collection for Shopify merchants. You may still need to collect local taxes in some jurisdictions.` : `Shopify automatically calculates sales tax for orders shipped within ${stateData.name}. Shipping charges may or may not be taxable depending on the specific product category — Shopify Tax handles this automatically for most merchants.`}`
      }
    },
    {
      "@type": "Question",
      "name": `How do USPS shipping zones work from ${stateData.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${stateData.name} is in the ${regionLabel} region. USPS zones are based on distance from your origin ZIP code: Zone 1–2 covers local delivery within your state, Zone 3–4 covers nearby states, Zone 5–6 covers mid-range destinations, and Zone 7–8 covers coast-to-coast shipping. From ${stateData.name}, shipping to the ${regionLabel} region costs Zone ${selfZone} rates, while shipping cross-country costs Zone ${Math.max(...Object.values(ZONE_MATRIX[originRegion]))} rates.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the USPS Ground Advantage rate from ${stateData.name} in 2026?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `USPS Ground Advantage rates from ${stateData.name} in 2026 range from $${getRate(uspsGA, 16, selfZone)?.toFixed(2)} (1 lb, within ${regionLabel} region) to $${getRate(uspsGA, 16, Math.max(...Object.values(ZONE_MATRIX[originRegion])))?.toFixed(2)} (1 lb, cross-country). For heavier packages (5 lb), expect $${getRate(uspsGA, 80, selfZone)?.toFixed(2)}–$${getRate(uspsGA, 80, Math.max(...Object.values(ZONE_MATRIX[originRegion])))?.toFixed(2)}. USPS Ground Advantage replaced First Class Package Service and Parcel Select Ground in 2023.`
      }
    },
    {
      "@type": "Question",
      "name": `Should I use UPS or FedEx for shipping from ${stateData.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `For ground shipping from ${stateData.name}, UPS Ground and FedEx Ground have very similar rates. Both offer 1–5 business day delivery with full tracking. Key differences: UPS offers better rates for commercial accounts with high volume, FedEx has more drop-off locations in some ${stateData.name} areas, and FedEx Home Delivery reaches residential addresses on Saturdays. For packages under 1 lb, USPS typically beats both UPS and FedEx on price.`
      }
    }
  ]
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://shopify-shipping-calc.com/" },
    { "@type": "ListItem", "position": 2, "name": "Shipping by State", "item": "https://shopify-shipping-calc.com/shipping/" },
    { "@type": "ListItem", "position": 3, "name": stateData.name, "item": `https://shopify-shipping-calc.com/shipping/${stateData.slug}/` }
  ]
});
---
<Base
  title={`${stateData.name} Shipping Rates 2026 — USPS, UPS, FedEx & DHL Calculator`}
  description={`Compare USPS, UPS, FedEx, and DHL shipping rates from ${stateData.name} (${stateData.abbr}). Free calculator for any package weight. Zone ${selfZone} to Zone ${Math.max(...Object.values(ZONE_MATRIX[originRegion]))} rates updated 2026.`}
  canonicalUrl={`https://shopify-shipping-calc.com/shipping/${stateData.slug}/`}
  noWebAppSchema={true}
>
  <script type="application/ld+json" set:html={softwareSchema} slot="head" />
  <script type="application/ld+json" set:html={faqSchema} slot="head" />
  <script type="application/ld+json" set:html={breadcrumbSchema} slot="head" />

  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 dark:text-gray-400 mb-5 flex items-center gap-1 flex-wrap">
    <a href="/" class="hover:text-teal-700 dark:hover:text-teal-400">Home</a>
    <span>›</span>
    <a href="/shipping/" class="hover:text-teal-700 dark:hover:text-teal-400">Shipping by State</a>
    <span>›</span>
    <span class="text-gray-800 dark:text-gray-200">{stateData.name}</span>
  </nav>

  <h1 class="text-3xl font-bold mb-3">{stateData.name} ({stateData.abbr}) Shipping Rates 2026</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-2 text-lg max-w-3xl">
    Compare USPS, UPS, FedEx, and DHL shipping rates from {stateData.name}. Free calculator for any package weight — updated for 2026 commercial rates.
  </p>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-8 max-w-3xl">
    {stateData.name} is in the <strong class="text-gray-700 dark:text-gray-300">{regionLabel}</strong> shipping region. Local delivery (within {regionLabel}) uses <strong>Zone {selfZone}</strong> rates. Cross-country shipments to the West or Northeast reach <strong>Zone {Math.max(...Object.values(ZONE_MATRIX[originRegion]))}</strong>.
    State sales tax: <strong>{stateData.taxRate}%</strong>{stateData.taxRate === 0 ? ' (no state tax)' : ''}.
  </p>

  <!-- Quick Rate Calculator -->
  <div class="bg-teal-50 dark:bg-teal-950 border border-teal-200 dark:border-teal-800 rounded-2xl p-6 mb-8 max-w-3xl">
    <h2 class="text-lg font-semibold text-teal-900 dark:text-teal-100 mb-4">Quick Rate Calculator — from {stateData.name}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Package Weight</label>
        <select id="calcWeight" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
          <option value="1">1 oz</option>
          <option value="4">4 oz</option>
          <option value="8">8 oz</option>
          <option value="12">12 oz</option>
          <option value="16" selected>1 lb</option>
          <option value="32">2 lb</option>
          <option value="48">3 lb</option>
          <option value="80">5 lb</option>
          <option value="160">10 lb</option>
          <option value="320">20 lb</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Ship To</label>
        <select id="calcDest" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm">
          <option value="northeast">Northeast (NY, MA, PA, NJ…)</option>
          <option value="southeast">Southeast (FL, GA, NC, TX…)</option>
          <option value="midwest">Midwest (IL, OH, MI, MN…)</option>
          <option value="southwest">Southwest (AZ, CO, NM, NV…)</option>
          <option value="west">West Coast (CA, OR, WA…)</option>
        </select>
      </div>
      <div class="flex items-end">
        <button onclick="calcRates()" class="w-full bg-teal-700 hover:bg-teal-800 text-white font-medium py-2 px-4 rounded-lg transition text-sm">
          Calculate
        </button>
      </div>
    </div>
    <div id="calcResults" class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="bg-white dark:bg-gray-800 rounded-xl p-3 border border-gray-200 dark:border-gray-700 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">USPS Ground Adv.</p>
        <p id="r-uspsga" class="text-lg font-bold text-teal-700 dark:text-teal-400">—</p>
        <p class="text-xs text-gray-400">2–5 days</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-3 border border-gray-200 dark:border-gray-700 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">USPS Priority</p>
        <p id="r-uspspm" class="text-lg font-bold text-teal-700 dark:text-teal-400">—</p>
        <p class="text-xs text-gray-400">1–3 days</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-3 border border-gray-200 dark:border-gray-700 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">UPS Ground</p>
        <p id="r-ups" class="text-lg font-bold text-teal-700 dark:text-teal-400">—</p>
        <p class="text-xs text-gray-400">1–5 days</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-3 border border-gray-200 dark:border-gray-700 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">FedEx Ground</p>
        <p id="r-fedex" class="text-lg font-bold text-teal-700 dark:text-teal-400">—</p>
        <p class="text-xs text-gray-400">1–5 days</p>
      </div>
    </div>
    <p id="calcZone" class="text-xs text-gray-400 dark:text-gray-500 mt-3">Select destination and click Calculate to see rates.</p>
  </div>

  <!-- Cheapest carrier callout per destination -->
  <div class="mb-8 max-w-3xl">
    <h2 class="text-xl font-bold mb-4">Cheapest Carrier from {stateData.name} by Destination (1 lb)</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {destRegions.map(dest => {
        const zone = ZONE_MATRIX[originRegion][dest];
        const best = cheapestAtZone(zone);
        return (
          <div class="border border-gray-200 dark:border-gray-700 rounded-xl p-4 bg-white dark:bg-gray-800">
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">{regionLabels[dest]}</p>
            <p class="text-xs text-gray-400 mb-2">Zone {zone}</p>
            <p class="font-semibold text-teal-700 dark:text-teal-400">${best?.rate.toFixed(2)}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{best?.name}</p>
          </div>
        );
      })}
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">* Approximate 2026 commercial rates for a 1 lb package. Residential surcharges may apply for UPS/FedEx.</p>
  </div>

  <!-- Full rate comparison table -->
  <div class="mb-10 max-w-4xl">
    <h2 class="text-xl font-bold mb-4">Full Rate Table — USPS from {stateData.name} by Weight & Destination</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
      USPS Ground Advantage rates for packages shipped from {stateData.name} ({stateData.abbr}). Rates depend on destination zone.
    </p>
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="w-full text-sm min-w-[540px]">
        <thead class="bg-gray-50 dark:bg-gray-900">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-gray-700 dark:text-gray-300">Weight</th>
            {destRegions.map(dest => {
              const zone = ZONE_MATRIX[originRegion][dest];
              return (
                <th class="px-3 py-3 font-semibold text-gray-700 dark:text-gray-300 text-right">
                  {regionLabels[dest]}<br/><span class="font-normal text-xs text-gray-400">Zone {zone}</span>
                </th>
              );
            })}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {weightTiers.map((tier, i) => (
            <tr class={i % 2 === 0 ? 'bg-white dark:bg-gray-950' : 'bg-gray-50 dark:bg-gray-900'}>
              <td class="px-4 py-2.5 font-medium text-gray-800 dark:text-gray-200">{tier.label}</td>
              {destRegions.map(dest => {
                const zone = ZONE_MATRIX[originRegion][dest];
                const rate = getRate(uspsGA, tier.oz, zone);
                return (
                  <td class="px-3 py-2.5 text-right text-gray-700 dark:text-gray-300">
                    {rate ? `$${rate.toFixed(2)}` : '—'}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- UPS Ground table -->
    <h3 class="text-lg font-bold mt-6 mb-3">UPS Ground from {stateData.name}</h3>
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="w-full text-sm min-w-[540px]">
        <thead class="bg-gray-50 dark:bg-gray-900">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-gray-700 dark:text-gray-300">Weight</th>
            {destRegions.map(dest => {
              const zone = ZONE_MATRIX[originRegion][dest];
              return (
                <th class="px-3 py-3 font-semibold text-gray-700 dark:text-gray-300 text-right">
                  {regionLabels[dest]}<br/><span class="font-normal text-xs text-gray-400">Zone {zone}</span>
                </th>
              );
            })}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {weightTiers.filter(t => t.oz >= 16).map((tier, i) => (
            <tr class={i % 2 === 0 ? 'bg-white dark:bg-gray-950' : 'bg-gray-50 dark:bg-gray-900'}>
              <td class="px-4 py-2.5 font-medium text-gray-800 dark:text-gray-200">{tier.label}</td>
              {destRegions.map(dest => {
                const zone = ZONE_MATRIX[originRegion][dest];
                const rate = getRate(upsG, tier.oz, zone);
                return (
                  <td class="px-3 py-2.5 text-right text-gray-700 dark:text-gray-300">
                    {rate ? `$${rate.toFixed(2)}` : '—'}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">* UPS Ground does not publish Zone 1 rates — Zone 2 is the starting point for all UPS destinations. Residential surcharge of ~$5.50 applies for home deliveries.</p>
  </div>

  <!-- Carrier comparison summary -->
  <div class="max-w-3xl mb-10">
    <h2 class="text-xl font-bold mb-4">USPS vs UPS vs FedEx from {stateData.name}</h2>
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-900">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-700 dark:text-gray-300">Carrier</th>
            <th class="px-3 py-3 font-medium text-gray-700 dark:text-gray-300 text-center">Speed</th>
            <th class="px-3 py-3 font-medium text-gray-700 dark:text-gray-300 text-center">Best For</th>
            <th class="px-3 py-3 font-medium text-gray-700 dark:text-gray-300 text-right">1 lb local rate</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          <tr class="bg-white dark:bg-gray-950">
            <td class="px-4 py-3 font-semibold text-blue-800 dark:text-blue-400">USPS Ground Advantage</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">2–5 days</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">Under 1 lb, light packages</td>
            <td class="px-3 py-3 text-right font-medium">${getRate(uspsGA, 16, selfZone)?.toFixed(2)}</td>
          </tr>
          <tr class="bg-gray-50 dark:bg-gray-900">
            <td class="px-4 py-3 font-semibold text-blue-800 dark:text-blue-400">USPS Priority Mail</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">1–3 days</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">Speed + flat rate boxes</td>
            <td class="px-3 py-3 text-right font-medium">${getRate(uspsPM, 16, selfZone)?.toFixed(2)}</td>
          </tr>
          <tr class="bg-white dark:bg-gray-950">
            <td class="px-4 py-3 font-semibold text-amber-800 dark:text-amber-400">UPS Ground</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">1–5 days</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">Heavy packages, commercial</td>
            <td class="px-3 py-3 text-right font-medium">${getRate(upsG, 16, selfZone)?.toFixed(2)}</td>
          </tr>
          <tr class="bg-gray-50 dark:bg-gray-900">
            <td class="px-4 py-3 font-semibold text-orange-700 dark:text-orange-400">FedEx Ground</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">1–5 days</td>
            <td class="px-3 py-3 text-center text-gray-600 dark:text-gray-400">Residential Sat. delivery</td>
            <td class="px-3 py-3 text-right font-medium">${getRate(fedexG, 16, selfZone)?.toFixed(2) ?? '~$10'}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Cities in this state -->
  <div class="mb-10">
    <h2 class="text-xl font-bold mb-4">Shipping Rates by City in {stateData.name}</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
      Select a city below for a detailed shipping rate calculator with live zone lookup from that specific ZIP code.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {stateData.cities.map(city => (
        <a
          href={`/shipping/${stateData.slug}/${city.slug}/`}
          class="border border-gray-200 dark:border-gray-700 rounded-xl p-4 hover:border-teal-400 dark:hover:border-teal-600 hover:bg-teal-50 dark:hover:bg-teal-950 transition group"
        >
          <div class="font-medium text-sm text-gray-800 dark:text-gray-200 group-hover:text-teal-700 dark:group-hover:text-teal-400">{city.name}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">ZIP {city.zip}</div>
        </a>
      ))}
    </div>
  </div>

  <!-- Shopify shipping tips section -->
  <div class="max-w-3xl mb-10 bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold mb-4">Shopify Shipping from {stateData.name}: Tips for 2026</h2>
    <div class="space-y-4 text-sm text-gray-700 dark:text-gray-300">
      <div>
        <h3 class="font-semibold text-gray-800 dark:text-gray-200 mb-1">Connect your Shopify store to USPS discounts</h3>
        <p>Shopify merchants in {stateData.name} get up to <strong>88% off USPS rates</strong> and up to <strong>77% off UPS rates</strong> through Shopify Shipping. These commercial discounts are far better than walking into the post office — especially for {stateData.name}'s most competitive shipping routes.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-800 dark:text-gray-200 mb-1">Free shipping threshold for {stateData.name} stores</h3>
        <p>The average free shipping threshold for Shopify stores is $50–$75. For {stateData.name} merchants shipping within the {regionLabel} region at Zone {selfZone} rates, a 1–2 lb order costs $${getRate(uspsGA, 16, selfZone)?.toFixed(2)}–$${getRate(uspsGA, 32, selfZone)?.toFixed(2)} to ship — build this into your product pricing or minimum order threshold. Use our <a href="/free-shipping-threshold/" class="text-teal-700 dark:text-teal-400 hover:underline">free shipping threshold calculator</a>.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-800 dark:text-gray-200 mb-1">{stateData.name} sales tax on Shopify</h3>
