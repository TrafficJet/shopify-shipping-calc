        ))}
      </div>
    </div>
  )}

  <!-- Footer CTA -->
  <div class="max-w-3xl p-4 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 text-sm">
    <p class="font-semibold text-gray-700 dark:text-gray-300 mb-2">More Shipping Tools</p>
    <div class="flex flex-wrap gap-2">
      <a href="/shipping-calculator/" class="px-3 py-1.5 bg-teal-50 dark:bg-teal-950 text-teal-700 dark:text-teal-400 rounded-lg border border-teal-200 dark:border-teal-800 hover:shadow-sm">Full Rate Calculator</a>
      <a href="/dimensional-weight/" class="px-3 py-1.5 bg-teal-50 dark:bg-teal-950 text-teal-700 dark:text-teal-400 rounded-lg border border-teal-200 dark:border-teal-800 hover:shadow-sm">DIM Weight Calculator</a>
      <a href="/free-shipping-threshold/" class="px-3 py-1.5 bg-teal-50 dark:bg-teal-950 text-teal-700 dark:text-teal-400 rounded-lg border border-teal-200 dark:border-teal-800 hover:shadow-sm">Free Shipping Threshold</a>
      <a href="/carrier-comparison/" class="px-3 py-1.5 bg-teal-50 dark:bg-teal-950 text-teal-700 dark:text-teal-400 rounded-lg border border-teal-200 dark:border-teal-800 hover:shadow-sm">Carrier Comparison</a>
      <a href="/china-shipping/" class="px-3 py-1.5 bg-teal-50 dark:bg-teal-950 text-teal-700 dark:text-teal-400 rounded-lg border border-teal-200 dark:border-teal-800 hover:shadow-sm">China Shipping Rates</a>
      <a href="/shipping/" class="px-3 py-1.5 bg-teal-50 dark:bg-teal-950 text-teal-700 dark:text-teal-400 rounded-lg border border-teal-200 dark:border-teal-800 hover:shadow-sm">← All States</a>
    </div>
  </div>
</Base>

<script define:vars={{ originRegion, ZONE_MATRIX: JSON.parse(JSON.stringify(ZONE_MATRIX)) }}>
  // Rate data embedded from carriers
  const RATES = {
    uspsga: {
      1:  {1:3.79,2:3.79,3:3.95,4:4.16,5:4.50,6:4.80,7:5.10,8:5.45},
      4:  {1:4.29,2:4.29,3:4.55,4:4.85,5:5.30,6:5.75,7:6.20,8:6.75},
      8:  {1:4.79,2:4.79,3:5.25,4:5.75,5:6.35,6:7.00,7:7.65,8:8.30},
      12: {1:5.19,2:5.19,3:5.85,4:6.50,5:7.30,6:8.20,7:9.10,8:9.95},
      16: {1:5.49,2:5.49,3:6.35,4:7.10,5:8.10,6:9.20,7:10.35,8:11.50},
      32: {1:6.35,2:6.35,3:7.45,4:8.50,5:9.90,6:11.50,7:13.00,8:14.60},
      48: {1:7.20,2:7.20,3:8.55,4:9.90,5:11.70,6:13.80,7:15.65,8:17.70},
      80: {1:9.25,2:9.25,3:11.20,4:13.20,5:15.80,6:18.90,7:21.50,8:24.50},
      160:{1:14.50,2:14.50,3:18.50,4:22.50,5:27.50,6:33.50,7:38.50,8:44.00},
      320:{1:25.50,2:25.50,3:33.00,4:41.00,5:51.00,6:63.00,7:73.00,8:84.00},
    },
    uspspm: {
      16: {1:8.50,2:8.50,3:9.10,4:9.55,5:10.40,6:11.20,7:12.15,8:13.25},
      32: {1:9.35,2:9.35,3:10.15,4:11.05,5:12.45,6:13.85,7:15.70,8:17.70},
      48: {1:10.20,2:10.20,3:11.20,4:12.55,5:14.50,6:16.50,7:19.25,8:22.15},
      80: {1:12.55,2:12.55,3:14.55,4:16.70,5:19.45,6:22.90,7:26.75,8:30.90},
      160:{1:19.30,2:19.30,3:21.65,4:25.55,5:31.00,6:37.60,7:44.55,8:52.35},
      320:{1:34.50,2:34.50,3:39.50,4:47.50,5:58.00,6:71.00,7:84.00,8:99.00},
    },
    ups: {
      16: {2:9.50,3:10.25,4:10.95,5:12.25,6:13.75,7:15.25,8:17.00},
      32: {2:10.75,3:11.75,4:12.75,5:14.50,6:16.50,7:18.50,8:20.75},
      48: {2:11.50,3:12.75,4:13.95,5:16.00,6:18.50,7:21.00,8:23.75},
      80: {2:12.50,3:13.80,4:15.25,5:17.50,6:20.25,7:23.50,8:27.00},
      160:{2:16.50,3:18.50,4:20.50,5:24.50,6:29.00,7:34.50,8:40.50},
      320:{2:22.50,3:25.50,4:28.50,5:34.50,6:41.50,7:50.00,8:59.00},
    },
    fedex: {
      16: {2:9.75,3:10.50,4:11.25,5:12.50,6:14.00,7:15.50,8:17.25},
      32: {2:11.00,3:12.00,4:13.00,5:14.75,6:16.75,7:18.75,8:21.25},
      48: {2:11.75,3:13.00,4:14.25,5:16.25,6:18.75,7:21.25,8:24.25},
      80: {2:12.75,3:14.25,4:15.75,5:18.00,6:20.75,7:24.00,8:27.50},
      160:{2:17.00,3:19.00,4:21.00,5:25.00,6:29.75,7:35.00,8:41.00},
      320:{2:23.00,3:26.25,4:29.25,5:35.25,6:42.50,7:51.00,8:60.00},
    },
  };

  function getRate(table, oz, zone) {
    const ozKeys = Object.keys(table).map(Number).sort((a,b)=>a-b);
    const key = ozKeys.find(k => k >= oz) || ozKeys[ozKeys.length-1];
    return table[key]?.[zone] ?? null;
  }

  function calcRates() {
    const oz = parseInt(document.getElementById('calcWeight').value);
    const dest = document.getElementById('calcDest').value;
    const zone = ZONE_MATRIX[originRegion][dest];

    const r = {
      uspsga: getRate(RATES.uspsga, oz, zone),
      uspspm: getRate(RATES.uspspm, oz, zone),
      ups:    getRate(RATES.ups,    oz, zone),
      fedex:  getRate(RATES.fedex,  oz, zone),
    };

    document.getElementById('r-uspsga').textContent = r.uspsga ? '$' + r.uspsga.toFixed(2) : '—';
    document.getElementById('r-uspspm').textContent = r.uspspm ? '$' + r.uspspm.toFixed(2) : '—';
    document.getElementById('r-ups').textContent    = r.ups    ? '$' + r.ups.toFixed(2)    : '—';
    document.getElementById('r-fedex').textContent  = r.fedex  ? '$' + r.fedex.toFixed(2)  : '—';
    document.getElementById('calcZone').textContent = `Zone ${zone} (shipping to ${dest.charAt(0).toUpperCase() + dest.slice(1)}). Rates are approximate 2026 commercial rates.`;

    // Highlight cheapest
    const vals = [
      {id:'r-uspsga', v: r.uspsga},
      {id:'r-uspspm', v: r.uspspm},
      {id:'r-ups',    v: r.ups},
      {id:'r-fedex',  v: r.fedex},
    ].filter(x => x.v !== null);
    const minV = Math.min(...vals.map(x => x.v));
    vals.forEach(x => {
      const el = document.getElementById(x.id);
      if (x.v === minV) {
        el.className = 'text-lg font-bold text-green-600 dark:text-green-400';
      } else {
        el.className = 'text-lg font-bold text-teal-700 dark:text-teal-400';
      }
    });
  }

  // Auto-calculate on page load
  document.addEventListener('DOMContentLoaded', calcRates);
</script>
