---
import Base from "../../../layouts/Base.astro";
import { states, ZONE_MATRIX } from "../../../data/states-cities";
import { carriers, getRateForZone, compareRates } from "../../../data/carriers-rates";
import { productCategories } from "../../../data/product-categories";

export function getStaticPaths() {
  return states.flatMap(s =>
    s.cities.map(c => ({ params: { state: s.slug, city: c.slug } }))
  );
}

const { state: stateSlug, city: citySlug } = Astro.params;
const stateData = states.find(s => s.slug === stateSlug)!;
const cityData = stateData.cities.find(c => c.slug === citySlug)!;
const originRegion = cityData.region;

const regions = ['northeast', 'southeast', 'midwest', 'southwest', 'west'] as const;
const regionLabels: Record<string, string> = {
  northeast: 'Northeast', southeast: 'Southeast',
  midwest: 'Midwest', southwest: 'Southwest', west: 'West',
};

// Zone to each destination region
const zoneMap = Object.fromEntries(regions.map(r => [r, ZONE_MATRIX[originRegion][r]]));

// For the "cheapest by category" table: find cheapest carrier for each category's typical weight
// to the most distant zone from this city
const farthestZone = Math.max(...regions.map(r => zoneMap[r]));
const midZone = Math.round(Object.values(zoneMap).reduce((a,b)=>a+b,0) / 5);

function cheapestCarrier(weightOz: number, zone: number) {
  return compareRates(weightOz, zone).filter(x => x.rate !== null)[0];
}

function zoneBgClass(z: number): string {
  if (z < 4) return 'bg-green-50 border-green-300 text-green-800';
  if (z < 6) return 'bg-yellow-50 border-yellow-300 text-yellow-800';
  return 'bg-red-50 border-red-300 text-red-800';
}

function zoneTextClass(z: number): string {
  if (z < 4) return 'text-green-700';
  if (z < 7) return 'text-gray-700';
  return 'text-red-600';
}

function fmtWeight(oz: number): string {
  return oz >= 16 ? `${(oz / 16).toFixed(1)} lb` : `${oz} oz`;
}

// Pre-compute category cards (cheapest carrier + rate for typical weight, zone = avg)
const categoryCards = productCategories.map(cat => {
  const zone = midZone;
  const best = cheapestCarrier(cat.typicalWeightOz, zone);
  return { cat, best };
});

// For "savings by product" example: compare cheapest vs most expensive carrier at midZone for each category
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the cheapest way to ship clothing from ${cityData.name}, ${stateData.abbr}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": (() => {
          const zone = zoneMap['midwest'];
          const best = cheapestCarrier(8, zone);
          return `For a typical t-shirt (8 oz) shipped from ${cityData.name} to the Midwest (Zone ${zone}), the cheapest option is ${best?.carrier.name} at $${best?.rate?.toFixed(2)}. USPS Ground Advantage is typically the best value for clothing under 2 lbs.`;
        })(),
      },
    },
    {
      "@type": "Question",
      "name": `Which carrier is best for shipping electronics from ${cityData.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": (() => {
          const zone = zoneMap['west'];
          const best = cheapestCarrier(16, zone);
          return `For electronics (typically 8–32 oz) shipped from ${cityData.name}, ${best?.carrier.name} offers competitive rates. For high-value items, UPS and FedEx include $100 insurance and better claims handling.`;
        })(),
      },
    },
    {
      "@type": "Question",
      "name": `How much does it cost to ship from ${cityData.name} to the West Coast?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": (() => {
          const zone = zoneMap['west'];
          const best = cheapestCarrier(16, zone);
          return `Shipping a 1 lb package from ${cityData.name} to the West Coast (Zone ${zone}) costs from $${best?.rate?.toFixed(2)} via ${best?.carrier.name}. Heavier packages of 5 lb cost from $${cheapestCarrier(80, zone)?.rate?.toFixed(2)}.`;
        })(),
      },
    },
  ],
});
---
<Base
  title={`Shipping from ${cityData.name}, ${stateData.abbr} — Rates by Product Type 2026`}
  description={`Cheapest shipping from ${cityData.name} for every Shopify product category. USPS, UPS, FedEx, DHL rates for clothing, electronics, jewelry, beauty, and 15 more categories. 2026 rates.`}
  canonicalUrl={`https://shopify-fee-calc.com/shipping/${stateData.slug}/${cityData.slug}/`}
>
  <script type="application/ld+json" set:html={schema} />

  <nav class="text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-700">Home</a>
    <span class="mx-2">›</span>
    <a href="/shipping/" class="hover:text-blue-700">Shipping</a>
    <span class="mx-2">›</span>
    <a href={`/shipping/${stateData.slug}/`} class="hover:text-blue-700">{stateData.name}</a>
    <span class="mx-2">›</span>
    <span class="text-gray-900">{cityData.name}</span>
  </nav>

  <h1 class="text-3xl font-bold mb-2">Shipping from {cityData.name}, {stateData.abbr}</h1>
  <p class="text-gray-500 mb-4 text-sm">ZIP {cityData.zip} · Region: <span class="capitalize font-medium text-gray-700">{originRegion}</span> · 2026 Rates · All major carriers</p>

  <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-2.5 mb-6 text-xs text-amber-800 flex items-start gap-2">
    <span class="mt-0.5 shrink-0">⚠️</span>
    <span>Rates are <strong>approximate estimates</strong> based on published 2026 carrier schedules. Actual rates vary by account type, surcharges, and package dimensions. <a href="/terms/" class="underline hover:text-amber-900">See full disclaimer →</a></span>
  </div>

  <!-- ── Zone quick-reference ─────────────────────────────────────────────── -->
  <div class="grid grid-cols-5 gap-2 mb-8 max-w-2xl">
    {regions.map(r => {
      const z = zoneMap[r];
      const colorClass = zoneBgClass(z);
      return (
        <div class={`border rounded-lg p-3 text-center ${colorClass}`}>
          <div class="text-lg font-bold">Z{z}</div>
          <div class="text-xs mt-0.5">{regionLabels[r]}</div>
        </div>
      );
    })}
  </div>

  <!-- ── Interactive rate calculator ─────────────────────────────────────── -->
  <div class="bg-gray-50 border rounded-xl p-6 max-w-2xl mb-10">
    <h2 class="font-semibold text-lg mb-4">Rate Calculator</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
      <div class="col-span-2 sm:col-span-1">
        <label class="block text-xs font-medium mb-1">Product Category</label>
        <select id="cat-select" class="w-full border rounded-lg px-2 py-2 text-sm">
          <option value="">— custom weight —</option>
          {productCategories.map(c => (
            <option value={c.typicalWeightOz}>{c.icon} {c.name}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium mb-1">Weight</label>
        <div class="flex gap-1">
          <input id="pkg-weight" type="number" min="0.1" step="0.1" value="1"
            class="w-full border rounded-lg px-2 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" />
          <select id="weight-unit" class="border rounded-lg px-1 py-2 text-sm">
            <option value="oz">oz</option>
            <option value="lb" selected>lb</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium mb-1">Destination</label>
        <select id="dest-region" class="w-full border rounded-lg px-2 py-2 text-sm">
          {regions.map(r => {
            const z = zoneMap[r];
            return <option value={`${r}:${z}`}>{regionLabels[r]} (Z{z})</option>;
          })}
        </select>
      </div>
      <div class="flex items-end">
        <button id="calc-btn"
          class="w-full bg-blue-700 text-white py-2 rounded-lg font-semibold text-sm hover:bg-blue-800 transition">
          Compare
        </button>
      </div>
    </div>
    <div id="calc-results" class="hidden">
      <div id="rates-list" class="space-y-2"></div>
    </div>
  </div>

  <!-- ── Cheapest carrier by product category ─────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-bold mb-2">Best Carrier for Each Product Type</h2>
    <p class="text-sm text-gray-500 mb-5">
      Cheapest carrier from {cityData.name} to the average US destination (Zone {midZone}), sorted by Shopify category.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryCards.map(({ cat, best }) => {
        const worstZone = farthestZone;
        const worstBest = cheapestCarrier(cat.typicalWeightOz, worstZone);
        return (
          <div class="border rounded-xl p-4 hover:shadow-sm transition" id={`cat-${cat.id}`}>
            <div class="flex items-start justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="text-xl">{cat.icon}</span>
                <h3 class="font-semibold text-sm">{cat.name}</h3>
              </div>
              <span class="text-xs text-gray-400">~{fmtWeight(cat.typicalWeightOz)}</span>
            </div>

            <div class="bg-green-50 rounded-lg px-3 py-2 mb-3">
              <div class="text-xs text-green-700 font-medium">Best value (Zone {midZone})</div>
              <div class="flex justify-between items-center mt-0.5">
                <span class="text-sm font-semibold">{best?.carrier.name}</span>
                <span class="text-green-700 font-bold">${best?.rate?.toFixed(2)}</span>
              </div>
              <div class="text-xs text-gray-500">{best?.carrier.speed}</div>
            </div>

            {worstBest && worstZone !== midZone && (
              <div class="text-xs text-gray-500 mb-2">
                Farthest (Zone {worstZone}): <span class="font-medium">${worstBest.rate?.toFixed(2)}</span> via {worstBest.carrier.name}
              </div>
            )}

            <div class="text-xs text-gray-400 leading-relaxed">{cat.description.split('.')[0]}.</div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ── Per-category detailed product tables ──────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-bold mb-2">Shipping Cost by Product — All Carriers</h2>
    <p class="text-sm text-gray-500 mb-6">
      Exact shipping costs from {cityData.name} for real Shopify products. Click a category to expand.
    </p>

    <div class="space-y-3" id="product-accordion">
      {productCategories.map((cat, idx) => (
        <div class="border rounded-xl overflow-hidden">
          <button
            class="w-full flex items-center justify-between px-5 py-4 text-left bg-white hover:bg-gray-50 transition accordion-btn"
            data-idx={idx}
          >
            <div class="flex items-center gap-3">
              <span class="text-lg">{cat.icon}</span>
              <div>
                <span class="font-semibold">{cat.name}</span>
                <span class="text-xs text-gray-500 ml-2">{cat.products.length} products</span>
              </div>
            </div>
            <span class="text-gray-400 accordion-arrow text-sm">▼</span>
          </button>

          <div class="accordion-body hidden px-5 pb-5">
            <p class="text-sm text-gray-600 mb-4">{cat.description}</p>

            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b text-gray-500 text-xs">
                    <th class="text-left pb-2 font-medium">Product</th>
                    <th class="pb-2 font-medium text-center">Weight</th>
                    <th class="pb-2 font-medium text-center">Price</th>
                    {regions.map(r => (
                      <th class="pb-2 font-medium text-right px-2">
                        {r.slice(0,2).toUpperCase()} Z{zoneMap[r]}
                      </th>
                    ))}
                    <th class="pb-2 font-medium text-left pl-3">Best Pick</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {cat.products.map(prod => {
                    return (
                      <tr class="hover:bg-gray-50">
                        <td class="py-2.5 font-medium pr-2">
                          {prod.name}
                          {prod.notes && <div class="text-xs text-orange-600">{prod.notes}</div>}
                        </td>
                        <td class="py-2.5 text-center text-gray-600 whitespace-nowrap">{fmtWeight(prod.weightOz)}</td>
                        <td class="py-2.5 text-center text-gray-500 text-xs whitespace-nowrap">{prod.priceRange}</td>
                        {regions.map(r => {
                          const z = zoneMap[r];
                          const best = cheapestCarrier(prod.weightOz, z);
                          return (
                            <td class="py-2.5 text-right px-2 whitespace-nowrap">
                              {best?.rate != null ? (
                                <span class={r === originRegion ? 'text-green-700 font-semibold' : 'text-gray-700'}>
                                  ${best.rate.toFixed(2)}
                                </span>
                              ) : '—'}
                            </td>
                          );
                        })}
                        <td class="py-2.5 pl-3">
                          {(() => {
                            const z = zoneMap[regions.find(r => r !== originRegion) ?? 'midwest'];
                            const top = compareRates(prod.weightOz, z).filter(x => x.rate !== null).slice(0, 2);
                            return (
                              <div class="text-xs">
                                <div class="text-green-700 font-medium">{top[0]?.carrier.name.split(' ').slice(-1)[0]}</div>
                                {top[1] && <div class="text-gray-400">{top[1].carrier.name.split(' ').slice(-1)[0]}</div>}
                              </div>
                            );
                          })()}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>

              </table>
            </div>

            <!-- Carrier comparison for this category's typical weight -->
            <div class="mt-5">
              <div class="text-xs font-medium text-gray-500 mb-2 uppercase tracking-wide">
                Carrier comparison — typical weight ({fmtWeight(cat.typicalWeightOz)}) · all destinations
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="border-b text-gray-400">
                      <th class="text-left pb-1.5 font-medium">Carrier</th>
                      <th class="pb-1.5 font-medium text-center">Speed</th>
                      {regions.map(r => (
                        <th class="pb-1.5 font-medium text-right px-2">Z{zoneMap[r]}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-50">
                    {carriers.map(carrier => {
                      const rates = regions.map(r => getRateForZone(carrier, cat.typicalWeightOz, zoneMap[r]));
                      if (rates.every(r => r === null)) return null;
                      const isMinInAny = rates.some((r, i) => {
                        const z = zoneMap[regions[i]];
                        const best = compareRates(cat.typicalWeightOz, z)[0];
                        return best?.carrier.id === carrier.id;
                      });
                      return (
                        <tr class={isMinInAny ? 'bg-green-50' : ''}>
                          <td class="py-1.5 font-medium">
                            {isMinInAny && <span class="text-green-600 mr-1">★</span>}
                            {carrier.name}
                          </td>
                          <td class="py-1.5 text-center text-gray-500">{carrier.speed}</td>
                          {rates.map(r => (
                            <td class="py-1.5 text-right px-2">
                              {r != null ? `$${r.toFixed(2)}` : '—'}
                            </td>
                          ))}
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Carrier quick-reference ─────────────────────────────────────────── -->
  <section class="mb-12 max-w-3xl">
    <h2 class="text-xl font-bold mb-4">Carrier Guide for {cityData.name} Sellers</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {[
        { id: 'usps-ground-advantage', tag: 'Best under 1 lb',   color: 'blue'  },
        { id: 'dhl-ecommerce',         tag: 'Cheapest overall',  color: 'yellow'},
        { id: 'ups-ground',            tag: 'Best 5–70 lb',      color: 'amber' },
        { id: 'fedex-ground',          tag: 'Reliable ground',   color: 'purple'},
        { id: 'usps-priority-mail',    tag: 'Best flat-rate',    color: 'blue'  },
        { id: 'ups-next-day',          tag: 'Overnight',         color: 'amber' },
      ].map(({ id, tag, color }) => {
        const carrier = carriers.find(c => c.id === id)!;
        if (!carrier) return null;
        const z = midZone;
        const rate1lb = getRateForZone(carrier, 16, z);
        const rate5lb = getRateForZone(carrier, 80, z);
        return (
          <div class={`border-l-4 border-${color}-400 rounded-r-xl p-4 bg-gray-50`}>
            <div class="flex justify-between items-start mb-1">
              <div class="font-semibold text-sm">{carrier.name}</div>
              <span class={`text-xs bg-${color}-100 text-${color}-700 px-2 py-0.5 rounded font-medium`}>{tag}</span>
            </div>
            <div class="text-xs text-gray-500 mb-2">{carrier.speed} · Insurance: {carrier.insuranceIncluded}</div>
            <div class="text-xs text-gray-600">{carrier.description}</div>
            {(rate1lb || rate5lb) && (
              <div class="mt-2 text-xs text-gray-500">
                Zone {z}: {rate1lb && <span>1 lb = <strong>${rate1lb.toFixed(2)}</strong></span>}
                {rate1lb && rate5lb && <span class="mx-1">·</span>}
                {rate5lb && <span>5 lb = <strong>${rate5lb.toFixed(2)}</strong></span>}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <!-- ── Other cities in state ────────────────────────────────────────────── -->
  <section class="mb-10 max-w-2xl">
    <h2 class="text-lg font-semibold mb-3">Other Cities in {stateData.name}</h2>
    <div class="flex flex-wrap gap-2">
      {stateData.cities.filter(c => c.slug !== cityData.slug).map(c => (
        <a href={`/shipping/${stateData.slug}/${c.slug}/`}
          class="text-sm text-blue-700 border border-blue-200 rounded-lg px-3 py-1 hover:bg-blue-50">
          {c.name}
        </a>
      ))}
    </div>
  </section>

  <div class="flex gap-4 text-sm flex-wrap">
    <a href={`/shipping/${stateData.slug}/`} class="text-blue-700 hover:underline">← {stateData.name} Overview</a>
    <a href="/shipping/" class="text-blue-700 hover:underline">All States</a>
    <a href="/china-shipping/" class="text-blue-700 hover:underline">China Shipping</a>
    <a href="/shipping-calculator/" class="text-blue-700 hover:underline">Full Calculator</a>
  </div>
</Base>

<script define:vars={{
  originRegion,
  zmJSON: JSON.stringify(ZONE_MATRIX),
  carriersJSON: JSON.stringify(carriers),
  catsJSON: JSON.stringify(productCategories),
}}>
  // ── Calculator ────────────────────────────────────────────────────────────
  const zm = JSON.parse(zmJSON);
  const allCarriers = JSON.parse(carriersJSON);
  const allCats = JSON.parse(catsJSON);

  function getRateForZone(carrier, weightOz, zone) {
    const z = Math.min(Math.max(zone, 1), 8);
    const sorted = [...carrier.rates].sort((a, b) => a.oz - b.oz);
    const bracket = sorted.find(r => r.oz >= weightOz) || sorted[sorted.length - 1];
    return bracket?.zones?.[z] ?? null;
  }

  // Category select pre-fills weight
  document.getElementById('cat-select').addEventListener('change', e => {
    const val = e.target.value;
    if (!val) return;
    const oz = parseFloat(val);
    const weightInput = document.getElementById('pkg-weight');
    const unitSelect = document.getElementById('weight-unit');
    if (oz >= 16) {
      weightInput.value = (oz / 16).toFixed(1);
      unitSelect.value = 'lb';
    } else {
      weightInput.value = oz;
      unitSelect.value = 'oz';
    }
  });

  document.getElementById('calc-btn').addEventListener('click', () => {
    const weightVal = parseFloat(document.getElementById('pkg-weight').value) || 1;
    const unit = document.getElementById('weight-unit').value;
    const weightOz = unit === 'lb' ? weightVal * 16 : weightVal;
    const [destRegion, zoneStr] = document.getElementById('dest-region').value.split(':');
    const zone = parseInt(zoneStr, 10);

    const results = allCarriers
      .map(c => ({ carrier: c, rate: getRateForZone(c, weightOz, zone) }))
      .filter(x => x.rate !== null)
      .sort((a, b) => a.rate - b.rate);

    const list = document.getElementById('rates-list');
    const savings = results.length > 1 ? (results[results.length-1].rate - results[0].rate).toFixed(2) : null;

    list.innerHTML = `
      ${savings ? `<div class="text-xs text-gray-500 mb-2">Save up to <strong>$${savings}</strong> by choosing the right carrier</div>` : ''}
      ${results.map((r, i) =>
        `<div class="flex items-center justify-between border rounded-lg px-4 py-2.5 ${i === 0 ? 'bg-green-50 border-green-300' : 'bg-white'}">
          <div class="flex items-center gap-2">
            ${i === 0 ? '<span class="text-xs font-medium text-green-700 bg-green-100 rounded px-1.5 py-0.5">Cheapest</span>' : `<span class="text-xs text-gray-400">#${i+1}</span>`}
            <div>
              <div class="font-medium text-sm">${r.carrier.name}</div>
              <div class="text-xs text-gray-500">${r.carrier.speed} · Insurance: ${r.carrier.insuranceIncluded}</div>
            </div>
          </div>
          <div class="text-right">
            <div class="font-bold text-sm ${i === 0 ? 'text-green-700' : 'text-gray-900'}">$${r.rate.toFixed(2)}</div>
            ${i > 0 ? `<div class="text-xs text-red-500">+$${(r.rate - results[0].rate).toFixed(2)}</div>` : ''}
          </div>
        </div>`
      ).join('')}
    `;
    document.getElementById('calc-results').classList.remove('hidden');
  });

  // ── Accordion ──────────────────────────────────────────────────────────────
  document.querySelectorAll('.accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const body = btn.nextElementSibling;
      const arrow = btn.querySelector('.accordion-arrow');
      const isOpen = !body.classList.contains('hidden');
      body.classList.toggle('hidden', isOpen);
      arrow.textContent = isOpen ? '▼' : '▲';
    });
  });
</script>
