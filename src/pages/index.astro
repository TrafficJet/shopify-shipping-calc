---
import Base from '../layouts/Base.astro';
---
<Base
  title="Shopify Shipping Calculator — Free Rate Tools for Sellers"
  description="Free shipping calculators for Shopify sellers: estimate USPS, UPS & FedEx rates, set the perfect free shipping threshold, and cut shipping costs."
>
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold mb-4">Free Shopify Shipping Tools</h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Accurate shipping calculators built for Shopify sellers. No login required.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
    <a href="/shipping-calculator/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Shipping Rate Calculator</h2>
      <p class="text-gray-600 text-sm">Compare USPS, UPS, and FedEx rates by weight, dimensions, and destination ZIP.</p>
    </a>
    <a href="/free-shipping-threshold/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Free Shipping Threshold</h2>
      <p class="text-gray-600 text-sm">Find the optimal free shipping minimum to boost AOV without killing margins.</p>
    </a>
    <a href="/blog/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">Shipping Guides</h2>
      <p class="text-gray-600 text-sm">In-depth guides on Shopify shipping zones, carrier rates, and fulfillment strategy.</p>
    </a>
    <a href="/about/" class="block border rounded-xl p-6 hover:shadow-md transition">
      <h2 class="text-xl font-semibold mb-2">About ShippingCalc</h2>
      <p class="text-gray-600 text-sm">Built by Shopify sellers, for Shopify sellers. Free forever.</p>
    </a>
  </section>
</Base>
